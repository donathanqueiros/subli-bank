# Variáveis de Ambiente para Produção (Coolify)

# GraphQL API URLs (Frontend)
VITE_GRAPHQL_URL=https://api.sua-dominio.com/graphql
VITE_GRAPHQL_WS_URL=wss://api.sua-dominio.com/graphql

# Database (Backend)
DATABASE_URL=mongodb+srv://user:password@host/database?replicaSet=rs0

# Node Environment
NODE_ENV=production
