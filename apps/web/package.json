{
  "name": "web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings 0",
    "check-types": "next typegen && tsc --noEmit",
    "relay:schema": "tsx scripts/generate-relay-schema.ts",
    "relay:compile": "relay-compiler",
    "relay": "pnpm relay:schema && pnpm relay:compile"
  },
  "relay": {
    "src": "./",
    "schema": "./schema.graphql",
    "language": "typescript",
    "excludes": [
      "**/node_modules/**",
      "**/.next/**",
      "**/dist/**"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@repo/ui": "workspace:*",
    "@tailwindcss/postcss": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "graphql": "^16.13.1",
    "lucide-react": "^0.577.0",
    "next": "16.2.0",
    "postcss": "^8.5.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-relay": "^20.1.1",
    "relay-runtime": "^20.1.1",
    "shadcn": "^4.0.8",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@types/react-relay": "^18.2.1",
    "@types/relay-runtime": "^20.1.1",
    "eslint": "^9.39.1",
    "relay-compiler": "^20.1.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.2"
  }
}
